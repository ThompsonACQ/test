rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // TESTING RULES (open access for development)
    // Comment these out and uncomment production
    // rules below before going live.
    // ============================================
    match /{allPaths=**} {
      allow read, write: if true;
    }

    // ============================================
    // PRODUCTION RULES (uncomment when ready)
    // Only authenticated users can upload images
    // Max 5 MB, must be an image file
    // ============================================
    // match /menuImages/{imageFile} {
    //   allow read: if true;
    //   allow write: if request.auth != null
    //                && request.resource.size < 5 * 1024 * 1024
    //                && request.resource.contentType.matches('image/.*');
    // }
  }
}
